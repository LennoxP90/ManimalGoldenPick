<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <RootNamespace>Manimal.GoldenPick</RootNamespace>
    <AssemblyName>GoldenPickClient</AssemblyName>
    <Nullable>disable</Nullable>
    <Authors>$(ModUsername)</Authors>
    <Configurations>Debug;Release</Configurations>
    <LangVersion>latest</LangVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <!-- forces transitive NuGet DLLs (BouncyCastle.Cryptography) to land in bin output.
         without this, PackageReference resolves at compile-time only — the DLL is not
         copied — and the BepInEx plugin fails to JIT any code that touches those types
         at runtime. silent failure: Harmony swallows the resolution exception, the
         patch effectively no-ops, vanilla EFT behavior takes over. -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <!--
    generates ModVersion.g.cs with a const string Plugin.cs uses for [BepInPlugin].
    attribute args must be const so we cant read the version at runtime — driving it
    off $(ModVersion) means a single bump in Directory.Build.props flows into the
    BepInPlugin attribute.
  -->
  <Target Name="GenerateModVersion" BeforeTargets="CoreCompile">
    <ItemGroup>
      <ModVersionLines Include="// auto-generated. edit ModVersion in Directory.Build.props." />
      <ModVersionLines Include="namespace Manimal.GoldenPick" />
      <ModVersionLines Include="{" />
      <ModVersionLines Include="    internal static class ModVersion" />
      <ModVersionLines Include="    {" />
      <ModVersionLines Include="        public const string Value = &quot;$(ModVersion)&quot;%3B" />
      <ModVersionLines Include="    }" />
      <ModVersionLines Include="}" />
    </ItemGroup>
    <MakeDir Directories="$(IntermediateOutputPath)" />
    <WriteLinesToFile File="$(IntermediateOutputPath)ModVersion.g.cs" Lines="@(ModVersionLines)" Overwrite="true" WriteOnlyWhenDifferent="true" />
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)ModVersion.g.cs" />
      <FileWrites Include="$(IntermediateOutputPath)ModVersion.g.cs" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <PackageReference Include="WTT-ClientCommonLib" Version="2.0.20" />
  </ItemGroup>

  <!--
    Hint paths point at the dev SPT install. If you move SPTDev, retarget these in
    one place. SpecificVersion=False on pinned refs tolerates minor BSG bumps without
    a csproj edit. broad reference set is carried over from the reference mods so the
    later milestones (gold-statue material swap, notifications) compile without churn.
  -->
  <ItemGroup>
    <Reference Include="0Harmony">
      <HintPath>F:\Games\SPT-4.0\BepInEx\core\0Harmony.dll</HintPath>
    </Reference>
    <Reference Include="BepInEx">
      <HintPath>F:\Games\SPT-4.0\BepInEx\core\BepInEx.dll</HintPath>
    </Reference>
    <Reference Include="spt-common">
      <HintPath>F:\Games\SPT-4.0\BepInEx\plugins\spt\spt-common.dll</HintPath>
    </Reference>
    <Reference Include="spt-reflection">
      <HintPath>F:\Games\SPT-4.0\BepInEx\plugins\spt\spt-reflection.dll</HintPath>
    </Reference>
    <Reference Include="Assembly-CSharp">
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\Assembly-CSharp.dll</HintPath>
    </Reference>
    <Reference Include="Comfort">
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\Comfort.dll</HintPath>
    </Reference>
    <Reference Include="Comfort.Unity">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\Comfort.Unity.dll</HintPath>
    </Reference>
    <Reference Include="ItemComponent.Types">
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\ItemComponent.Types.dll</HintPath>
    </Reference>
    <Reference Include="ItemTemplate.Types">
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\ItemTemplate.Types.dll</HintPath>
    </Reference>
    <Reference Include="Newtonsoft.Json">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\Newtonsoft.Json.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine">
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\UnityEngine.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\UnityEngine.CoreModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.InputLegacyModule">
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\UnityEngine.InputLegacyModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.PhysicsModule">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\UnityEngine.PhysicsModule.dll</HintPath>
    </Reference>
    <!-- EFT MonoBehaviours (ItemUiContext etc.) derive from Sirenix's SerializedMonoBehaviour,
         so referencing those types pulls Sirenix into type resolution even though we never
         use a Sirenix type directly. (same gotcha HackerMod documents.) -->
    <Reference Include="Sirenix.Serialization">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\Sirenix.Serialization.dll</HintPath>
    </Reference>
    <!-- for the upcoming FX overlay (RawImage / Canvas on the item cell) -->
    <Reference Include="UnityEngine.UI">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\UnityEngine.UI.dll</HintPath>
    </Reference>
    <!-- AudioSource / AudioClip for the reveal sound -->
    <Reference Include="UnityEngine.AudioModule">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\UnityEngine.AudioModule.dll</HintPath>
    </Reference>
    <!-- AssetBundle.LoadFromFile for loading the reveal bundles -->
    <Reference Include="UnityEngine.AssetBundleModule">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\UnityEngine.AssetBundleModule.dll</HintPath>
    </Reference>
    <!-- Canvas / RenderMode for the on-screen RawImage overlay -->
    <Reference Include="UnityEngine.UIModule">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\UnityEngine.UIModule.dll</HintPath>
    </Reference>
    <!-- ParticleSystem (waiting for the reveal to finish playing) -->
    <Reference Include="UnityEngine.ParticleSystemModule">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\UnityEngine.ParticleSystemModule.dll</HintPath>
    </Reference>
    <!-- IMGUI (OnGUI / GUIStyle / GUI.Box) for the debug raid-counter overlay -->
    <Reference Include="UnityEngine.IMGUIModule">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\UnityEngine.IMGUIModule.dll</HintPath>
    </Reference>
    <!-- TextRendering carries the FontStyle/TextAnchor enums GUIStyle uses -->
    <Reference Include="UnityEngine.TextRenderingModule">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\UnityEngine.TextRenderingModule.dll</HintPath>
    </Reference>
    <!-- TextMeshPro for the icon caption (TMP_Text) used by inventory name labels -->
    <Reference Include="Unity.TextMeshPro">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>F:\Games\SPT-4.0\EscapeFromTarkov_Data\Managed\Unity.TextMeshPro.dll</HintPath>
    </Reference>
  </ItemGroup>

  <!-- dev-time deploy: copy the DLL into the local SPTDev BepInEx plugins folder.
       killstreaksheen.bundle ships via the server PostBuild target alongside the other
       goldenpick bundles (goldmat, goldreveal etc) — keeping all bundles in one tree. -->
  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <MakeDir Directories="F:\Games\SPT-4.0\BepInEx\plugins\GoldenPick" />
    <Exec Command="copy &quot;$(TargetPath)&quot; &quot;F:\Games\SPT-4.0\BepInEx\plugins\GoldenPick\$(TargetFileName)&quot;" />
  </Target>

</Project>
